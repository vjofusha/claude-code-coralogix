# Coralogix Send-Your-Data API key
CX_API_KEY=your-coralogix-private-key-here

# Coralogix OTLP ingress endpoint (no protocol prefix, no signal suffix)
CX_OTLP_ENDPOINT=https://ingress.eu1.coralogix.com

# Coralogix application and subsystem names
CX_APPLICATION_NAME=claude-code
CX_SUBSYSTEM_NAME=claude-code-sessions
